# ============================================
# TCG Hub - Environment Configuration Template
# ============================================
# Hướng dẫn: 
# 1. Copy file này thành ".env"
# 2. Điền thông tin của bạn
# 3. Không commit .env file (thêm vào .gitignore)

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_SERVER=localhost
DB_USER=sa
DB_PASSWORD=your_password_here
DB_NAME=TCGHub
DB_PORT=1433

# ============================================
# MOMO PAYMENT - SANDBOX (TEST)
# ============================================
# 👉 Để test: Sử dụng thông tin test dưới đây
# 👉 Không cần tài khoản MoMo doanh nghiệp

MOMO_PARTNER_CODE=MOMO123456789
MOMO_ACCESS_KEY=F8BF53D3964D3F100DCA
MOMO_SECRET_KEY=9fc6c94460e4302d1c5f9d8e7f5b6a4c3d2e1a0b
MOMO_ENVIRONMENT=test
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# ============================================
# MOMO PAYMENT - PRODUCTION (After Going Live)
# ============================================
# 👉 Thay thế khi bạn có tài khoản MoMo thực

# MOMO_PARTNER_CODE=your_production_partner_code
# MOMO_ACCESS_KEY=your_production_access_key
# MOMO_SECRET_KEY=your_production_secret_key
# MOMO_ENVIRONMENT=production
# MOMO_ENDPOINT=https://payment.momo.vn/v2/gateway/api/create

# ============================================
# MOMO CALLBACK SETTINGS
# ============================================
# IPN URL: MoMo gửi thông báo xác nhận thanh toán
# REDIRECT URL: Người dùng quay lại sau khi thanh toán

MOMO_IPN_URL=http://localhost:3000/payment/notify
MOMO_REDIRECT_URL=http://localhost:3000/payment/callback

# Khi deploy lên server thực:
# MOMO_IPN_URL=https://yourdomain.com/payment/notify
# MOMO_REDIRECT_URL=https://yourdomain.com/payment/callback

# ============================================
# SERVER SETTINGS
# ============================================
PORT=3000
NODE_ENV=development

# Khi production:
# NODE_ENV=production
# PORT=8000 (hoặc port khác tùy cơ sở hạ tầng)

# ============================================
# JWT / AUTHENTICATION (Nếu cần)
# ============================================
# JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# ============================================
# UPLOAD / FILE STORAGE
# ============================================
# MAX_FILE_SIZE=5242880  # 5MB
# UPLOAD_DIR=./uploads

# ============================================
# EMAIL SETTINGS (Nếu dùng)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@tcghub.vn

# ============================================
# LOGGING
# ============================================
# LOG_LEVEL=debug  # debug, info, warn, error
# LOG_FILE=./logs/app.log
